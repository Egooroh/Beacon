{
  "title": "Beacon Overview",
  "uid": "beacon-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "tags": ["beacon"],
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Events Ingested (total)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "beacon_events_ingested_total",
        "legendFormat": "ingested"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Events Processed (total)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "beacon_events_processed_total",
        "legendFormat": "processed"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Issues Created (total)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "beacon_issues_created_total",
        "legendFormat": "issues"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Processing Lag",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "beacon_processing_lag",
        "legendFormat": "lag"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Ingest Rate (req/s)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(beacon_events_ingested_total[1m])",
        "legendFormat": "events/s"
      }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Ingest Latency (p50 / p95 / p99)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, rate(beacon_ingest_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(beacon_ingest_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, rate(beacon_ingest_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Alerts Sent by Type",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "rate(beacon_alerts_sent_total[5m])",
        "legendFormat": "{{type}}"
      }]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Processing Lag Over Time",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "beacon_processing_lag",
        "legendFormat": "unprocessed events"
      }]
    }
  ]
}
