# Required
BEACON_DB_DSN=postgres://beacon:beacon@localhost:5432/beacon?sslmode=disable

# Optional — override defaults shown below
BEACON_HTTP_ADDR=:8080
BEACON_LOG_LEVEL=info            # debug | info | warn | error
BEACON_PROCESS_INTERVAL=2s
BEACON_PROCESS_BATCH=100
BEACON_DIGEST_INTERVAL=1h
BEACON_SPIKE_FACTOR=5
BEACON_SPIKE_MIN=10
BEACON_ALERT_COOLDOWN=15m

# Secrets — leave empty to disable the feature
BEACON_TELEGRAM_TOKEN=
BEACON_SLACK_TOKEN=            # xoxb-... Bot OAuth token
BEACON_SENTRY_SECRET=          # HMAC secret for Sentry webhook validation

# Rate limiting
BEACON_INGEST_RATE_LIMIT=60    # requests per minute per IP on /ingest and Sentry webhook
